{
  "manifest_version": 3,
  "name": "Mojito ICT",
  "description": "Extension to work with Mojito localization instrumentation",
  "version": "0.1",
  "action": {
    "default_icon": "logo.png",
    "default_popup": "dist/popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["*://*/*", "file:///*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  }
}
