{
  "name": "currency-format",
  "source": "Total: {$amount :currency currency=$currency}",
  "expectedModel": {
    "type": "message",
    "declarations": [],
    "pattern": [
      "Total: ",
      {
        "type": "expression",
        "arg": { "type": "variable", "name": "amount" },
        "function": {
          "type": "function",
          "name": "currency",
          "options": {
            "currency": { "type": "variable", "name": "currency" }
          }
        }
      }
    ]
  },
  "formatCases": [
    {
      "locale": "en",
      "arguments": { "amount": 1234.5, "currency": "USD" },
      "expected": "Total: $1,234.50"
    },
    {
      "locale": "fr",
      "arguments": { "amount": 1234.5, "currency": "EUR" },
      "expected": "Total: 1\u202f234,50 €"
    },
    {
      "locale": "en",
      "arguments": { "amount": 1234, "currency": "JPY" },
      "expected": "Total: ¥1,234"
    }
  ]
}
