          "function": {
            "type": "function",
            "name": "percent",
            "options": {
              "select": { "type": "literal", "value": "exact" }
            }
          }
        }
      }
    ],
    "selectors": [{ "type": "variable", "name": "n" }],
    "variants": [
      {
        "keys": [{ "type": "literal", "value": "1.0" }],
        "value": ["One zero"]
      },
      {
        "keys": [{ "type": "literal", "value": "1" }],
        "value": ["One"]
      },
      {
        "keys": [{ "type": "*" }],
        "value": ["Other"]
      }
    ]
  },
  "formatCases": [
