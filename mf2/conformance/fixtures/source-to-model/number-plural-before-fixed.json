{
  "name": "number-plural-before-fixed",
  "source": ".input {$count :number}\n.match $count\n* {{fallback}}\none {{plural one}}\n1 {{exact one}}",
  "expectedModel": {
    "type": "select",
    "declarations": [
      {
        "type": "input",
        "name": "count",
        "value": {
          "type": "expression",
          "arg": { "type": "variable", "name": "count" },
          "function": { "type": "function", "name": "number" }
        }
      }
    ],
    "selectors": [{ "type": "variable", "name": "count" }],
    "variants": [
      {
        "keys": [{ "type": "*" }],
        "value": ["fallback"]
      },
      {
        "keys": [{ "type": "literal", "value": "one" }],
        "value": ["plural one"]
      },
      {
        "keys": [{ "type": "literal", "value": "1" }],
        "value": ["exact one"]
      }
    ]
  },
  "formatCases": [
    {
      "locale": "en",
      "arguments": { "count": 1 },
      "expected": "exact one"
    },
    {
      "locale": "en",
      "arguments": { "count": 2 },
      "expected": "fallback"
    }
  ]
}
