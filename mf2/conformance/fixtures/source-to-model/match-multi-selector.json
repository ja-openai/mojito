{
  "name": "match-multi-selector",
  "source": ".input {$gender :string}\n.input {$count :number}\n.match $gender $count\nmale one {{He has {$count} item}}\nfemale one {{She has {$count} item}}\nmale * {{He has {$count} items}}\nfemale * {{She has {$count} items}}\n* * {{They have {$count} items}}",
  "expectedModel": {
    "type": "select",
    "declarations": [
      {
        "type": "input",
        "name": "gender",
        "value": {
          "type": "expression",
          "arg": { "type": "variable", "name": "gender" },
          "function": { "type": "function", "name": "string" }
        }
      },
      {
        "type": "input",
        "name": "count",
        "value": {
          "type": "expression",
          "arg": { "type": "variable", "name": "count" },
          "function": { "type": "function", "name": "number" }
        }
      }
    ],
    "selectors": [
      { "type": "variable", "name": "gender" },
      { "type": "variable", "name": "count" }
    ],
    "variants": [
      {
        "keys": [
          { "type": "literal", "value": "male" },
          { "type": "literal", "value": "one" }
        ],
        "value": [
          "He has ",
          {
            "type": "expression",
            "arg": { "type": "variable", "name": "count" }
          },
          " item"
        ]
      },
      {
        "keys": [
          { "type": "literal", "value": "female" },
          { "type": "literal", "value": "one" }
        ],
        "value": [
          "She has ",
          {
            "type": "expression",
            "arg": { "type": "variable", "name": "count" }
          },
          " item"
        ]
      },
      {
        "keys": [
          { "type": "literal", "value": "male" },
          { "type": "*" }
        ],
        "value": [
          "He has ",
          {
            "type": "expression",
            "arg": { "type": "variable", "name": "count" }
          },
          " items"
        ]
      },
      {
        "keys": [
          { "type": "literal", "value": "female" },
          { "type": "*" }
        ],
        "value": [
          "She has ",
          {
            "type": "expression",
            "arg": { "type": "variable", "name": "count" }
          },
          " items"
        ]
      },
      {
        "keys": [
          { "type": "*" },
          { "type": "*" }
        ],
        "value": [
          "They have ",
          {
            "type": "expression",
            "arg": { "type": "variable", "name": "count" }
          },
          " items"
        ]
      }
    ]
  },
  "formatCases": [
    {
      "locale": "en",
      "arguments": { "gender": "male", "count": 1 },
      "expected": "He has 1 item"
    },
    {
      "locale": "en",
      "arguments": { "gender": "female", "count": 1 },
      "expected": "She has 1 item"
    },
    {
      "locale": "en",
      "arguments": { "gender": "male", "count": 2 },
      "expected": "He has 2 items"
    },
    {
      "locale": "en",
      "arguments": { "gender": "female", "count": 2 },
      "expected": "She has 2 items"
    },
    {
      "locale": "en",
      "arguments": { "gender": "unknown", "count": 1 },
      "expected": "They have 1 items"
    }
  ]
}
