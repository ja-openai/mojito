{
  "name": "@mojito-mf2/core",
  "version": "0.1.0",
  "description": "MessageFormat 2 parser and formatter for Mojito.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/box/mojito.git",
    "directory": "mf2/javascript"
  },
  "type": "module",
  "types": "./src/index.d.ts",
  "sideEffects": false,
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./formatter": {
      "types": "./src/formatter.d.ts",
      "import": "./src/formatter.js",
      "default": "./src/formatter.js"
    },
    "./parser": {
      "types": "./src/parser.d.ts",
      "import": "./src/parser.js",
      "default": "./src/parser.js"
    },
    "./portable": {
      "types": "./src/portable_functions.d.ts",
      "import": "./src/portable_functions.js",
      "default": "./src/portable_functions.js"
    },
    "./intl": {
      "types": "./src/intl_functions.d.ts",
      "import": "./src/intl_functions.js",
      "default": "./src/intl_functions.js"
    },
    "./number-core": {
      "types": "./src/number_core.d.ts",
      "import": "./src/number_core.js",
      "default": "./src/number_core.js"
    },
    "./date-time-core": {
      "types": "./src/date_time_core.d.ts",
      "import": "./src/date_time_core.js",
      "default": "./src/date_time_core.js"
    },
    "./relative-time-core": {
      "types": "./src/relative_time_core.d.ts",
      "import": "./src/relative_time_core.js",
      "default": "./src/relative_time_core.js"
    },
    "./cldr-packed": {
      "types": "./src/cldr_packed_resources.d.ts",
      "import": "./src/cldr_packed_resources.js",
      "default": "./src/cldr_packed_resources.js"
    }
  },
  "scripts": {
    "bench:format": "node tools/benchmark.js",
    "bench:cldr-data": "node --expose-gc tools/cldr-data-benchmark.js",
    "bench:parse": "node tools/parse-benchmark.js",
    "bench:plural": "node --expose-gc tools/plural-benchmark.js",
    "check": "node tests/package-boundary-test.js && node tests/number-core-test.js && node tests/date-time-core-test.js && node tests/relative-time-core-test.js && node tests/cldr-packed-resources-test.js && node tests/portable-functions-test.js && npm run check:types && node tools/conformance.js ../conformance/fixtures/source-to-model",
    "check:types": "tsc -p tsconfig.types.json",
    "demo": "node examples/demo.js",
    "demo:intl": "node examples/intl-demo.js",
    "generate:plurals": "sh ../cldr/update_generated.sh",
    "unicode-tests": "node tools/unicode-tests.js ../third_party/message-format-wg/test ../conformance/unicode-official-baseline.json"
  },
  "devDependencies": {
    "typescript": "~5.6.3"
  }
}
