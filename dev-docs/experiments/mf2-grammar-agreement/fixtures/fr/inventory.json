{
  "schema": "mf2-grammar-agreement/v0",
  "locale": "fr",
  "profile": "fr-v1",
  "messages": {
    "inventory.pickup": {
      "value": "Vous avez ramassé {$item :term article=definite role=object}.",
      "expects": {
        "item": {
          "type": "term",
          "requires": ["text", "forms.default"]
        }
      },
      "examples": [
        {
          "args": {
            "item": "item.sword"
          },
          "output": "Vous avez ramassé l'épée."
        },
        {
          "args": {
            "item": "item.shield"
          },
          "output": "Vous avez ramassé le bouclier."
        }
      ]
    },
    "inventory.new_item": {
      "value": "{$new :agree with=$item} {$item :term}.",
      "examples": [
        {
          "args": {
            "new": "adjective.new",
            "item": "item.sword"
          },
          "output": "nouvelle épée."
        }
      ]
    }
  },
  "terms": {
    "item.sword": {
      "text": "épée",
      "forms": {
        "default": ".input {$usage :string}\n.input {$number :string}\n.input {$count :number}\n.match $usage $number $count\nbare singular * {{épée}}\nbare plural * {{épées}}\ndefinite singular * {{l'épée}}\ndefinite plural * {{les épées}}\nindefinite singular * {{une épée}}\nindefinite plural * {{des épées}}\ncount * one {{une épée}}\ncount * other {{{$count} épées}}\n* * * {{épée}}"
      },
      "morphology": {
        "partOfSpeech": "noun",
        "gender": "feminine",
        "number": "singular",
        "phonology": {
          "elides": true
        },
        "forms": {
          "plural": "épées"
        }
      }
    },
    "item.shield": {
      "text": "bouclier",
      "forms": {
        "default": ".input {$usage :string}\n.input {$number :string}\n.input {$count :number}\n.match $usage $number $count\nbare singular * {{bouclier}}\nbare plural * {{boucliers}}\ndefinite singular * {{le bouclier}}\ndefinite plural * {{les boucliers}}\nindefinite singular * {{un bouclier}}\nindefinite plural * {{des boucliers}}\ncount * one {{un bouclier}}\ncount * other {{{$count} boucliers}}\n* * * {{bouclier}}"
      },
      "morphology": {
        "partOfSpeech": "noun",
        "gender": "masculine",
        "number": "singular",
        "phonology": {
          "elides": false
        },
        "forms": {
          "plural": "boucliers"
        }
      }
    },
    "adjective.new": {
      "text": "nouveau",
      "morphology": {
        "partOfSpeech": "adjective",
        "forms": {
          "masculine.singular": "nouveau",
          "feminine.singular": "nouvelle",
          "masculine.plural": "nouveaux",
          "feminine.plural": "nouvelles"
        }
      }
    }
  },
  "compactTerms": {
